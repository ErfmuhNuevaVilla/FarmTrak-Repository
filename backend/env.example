# Server
PORT=4000
FRONTEND_ORIGIN=http://localhost:5173

# Postgres (choose ONE option)
# Option A: single connection string (common in hosting providers)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/farmtrak
# Option B: individual parts (common in local dev)
# DB_USER=postgres
# DB_HOST=localhost
# DB_NAME=FarmTrakDB
# DB_PASS=12345678
# DB_PORT=5432

# Auth
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

